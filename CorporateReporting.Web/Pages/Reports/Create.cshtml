@page
@model CorporateReporting.Web.Pages.Reports.CreateModel
@using System.Text.Json

@{
    Layout = null;
    ViewData["Title"] = "Yeni Rapor";
    var selectedTableId = Model.Request.ReportableTableId;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Yeni Rapor | Corporate Reporting</title>

    <style>
        :root {
            --navy: #0a1731;
            --blue: #386fff;
            --cyan: #20d6ca;
            --bg: #f4f7fc;
            --surface: #ffffff;
            --line: #e7edf6;
            --text: #1b2945;
            --muted: #8190a8;
            --green: #18ad7e;
            --red: #d95067;
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            color: var(--text);
            background: var(--bg);
            font-family: Inter, "Segoe UI", Arial, sans-serif;
        }

        .topbar {
            height: 72px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 38px;
            background: #fff;
            border-bottom: 1px solid var(--line);
        }

        .brand {
            display: flex;
            align-items: center;
            gap: 11px;
            color: var(--navy);
            font-size: 16px;
            font-weight: 800;
            text-decoration: none;
        }

        .brand-mark {
            width: 37px;
            height: 37px;
            display: grid;
            place-items: center;
            border-radius: 11px;
            background: linear-gradient(135deg, var(--cyan), var(--blue));
        }

        .back-link {
            color: #61708b;
            font-size: 13px;
            font-weight: 650;
            text-decoration: none;
        }

        .page {
            max-width: 1320px;
            margin: 0 auto;
            padding: 36px;
        }

        .page-heading {
            display: flex;
            align-items: flex-end;
            justify-content: space-between;
            gap: 20px;
            margin-bottom: 29px;
        }

        .breadcrumb {
            margin-bottom: 9px;
            color: var(--blue);
            font-size: 12px;
            font-weight: 750;
            letter-spacing: .2px;
            text-transform: uppercase;
        }

        h1 {
            margin: 0;
            color: var(--navy);
            font-size: 30px;
            letter-spacing: -1px;
        }

        .page-heading p {
            margin: 9px 0 0;
            color: var(--muted);
            font-size: 14px;
        }

        .source-card {
            margin-bottom: 22px;
            padding: 22px;
            border: 1px solid var(--line);
            border-radius: 16px;
            background: var(--surface);
        }

        .section-title {
            display: flex;
            align-items: center;
            gap: 10px;
            margin: 0 0 7px;
            color: var(--navy);
            font-size: 16px;
        }

        .section-subtitle {
            margin: 0 0 18px;
            color: var(--muted);
            font-size: 13px;
        }

        .source-select {
            width: 100%;
            max-width: 500px;
            height: 51px;
            padding: 0 14px;
            border: 1px solid var(--line);
            border-radius: 11px;
            outline: none;
            background: #fff;
            color: var(--text);
            font: inherit;
        }

            .source-select:focus,
            .select-field:focus,
            .text-field:focus {
                border-color: var(--blue);
                box-shadow: 0 0 0 4px rgba(56, 111, 255, .1);
            }

        .report-layout {
            display: grid;
            grid-template-columns: minmax(0, 1.05fr) minmax(330px, .95fr);
            gap: 22px;
        }

        .panel {
            padding: 23px;
            border: 1px solid var(--line);
            border-radius: 16px;
            background: var(--surface);
        }

        .panel-header {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 15px;
            margin-bottom: 20px;
        }

            .panel-header h2 {
                margin: 0 0 6px;
                font-size: 16px;
            }

            .panel-header p {
                margin: 0;
                color: var(--muted);
                font-size: 12px;
                line-height: 1.55;
            }

        .column-grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 10px;
        }

        .column-option {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 12px;
            border: 1px solid var(--line);
            border-radius: 10px;
            cursor: pointer;
            transition: .18s ease;
        }

            .column-option:hover {
                border-color: #b8caff;
                background: #f8faff;
            }

            .column-option input {
                width: 16px;
                height: 16px;
                accent-color: var(--blue);
            }

        .column-name {
            display: block;
            color: #33415b;
            font-size: 13px;
            font-weight: 650;
        }

        .column-type {
            display: block;
            margin-top: 3px;
            color: #98a4b8;
            font-size: 10px;
            text-transform: uppercase;
        }

        .filter-list {
            display: grid;
            gap: 10px;
        }

        .filter-row {
            display: grid;
            grid-template-columns: 1.2fr 1fr 1fr auto;
            gap: 9px;
            align-items: center;
        }

        .select-field,
        .text-field {
            width: 100%;
            height: 42px;
            padding: 0 10px;
            border: 1px solid var(--line);
            border-radius: 9px;
            outline: none;
            background: #fff;
            color: #384660;
            font: inherit;
            font-size: 12px;
        }

        .remove-filter {
            width: 38px;
            height: 38px;
            border: 1px solid #ffdce1;
            border-radius: 9px;
            background: #fff7f8;
            color: var(--red);
            cursor: pointer;
            font-size: 17px;
        }

        .add-filter {
            margin-top: 13px;
            padding: 0;
            border: 0;
            background: transparent;
            color: var(--blue);
            cursor: pointer;
            font: inherit;
            font-size: 13px;
            font-weight: 750;
        }

        .sort-box {
            margin-top: 25px;
            padding-top: 20px;
            border-top: 1px solid #eef2f7;
        }

        .sort-grid {
            display: grid;
            grid-template-columns: 1.5fr .8fr;
            gap: 10px;
        }

        .run-button {
            width: 100%;
            height: 53px;
            margin-top: 25px;
            border: 0;
            border-radius: 11px;
            background: linear-gradient(135deg, #386fff, #2857dd);
            box-shadow: 0 12px 22px rgba(56, 111, 255, .22);
            color: #fff;
            cursor: pointer;
            font: inherit;
            font-size: 14px;
            font-weight: 750;
            transition: transform .18s ease;
        }

            .run-button:hover {
                transform: translateY(-2px);
            }

        .empty-state {
            padding: 48px 25px;
            border: 1px dashed #cbd7ea;
            border-radius: 16px;
            background: rgba(255, 255, 255, .55);
            color: var(--muted);
            text-align: center;
        }

        .empty-icon {
            width: 53px;
            height: 53px;
            display: grid;
            place-items: center;
            margin: 0 auto 13px;
            border-radius: 15px;
            background: #eaf0ff;
            color: var(--blue);
            font-size: 25px;
        }

        .validation-summary-errors {
            margin: 0 0 18px;
            padding: 13px 15px;
            border: 1px solid #ffd7de;
            border-radius: 10px;
            background: #fff5f6;
            color: var(--red);
            font-size: 13px;
        }

            .validation-summary-errors ul {
                margin: 0;
                padding-left: 18px;
            }

        .result-panel {
            margin-top: 22px;
            overflow: hidden;
            border: 1px solid var(--line);
            border-radius: 16px;
            background: #fff;
        }

        .result-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 20px 23px;
            border-bottom: 1px solid var(--line);
        }

            .result-header h2 {
                margin: 0;
                font-size: 16px;
            }

        .row-count {
            padding: 6px 10px;
            border-radius: 20px;
            background: #e6f8f1;
            color: var(--green);
            font-size: 11px;
            font-weight: 750;
        }

        .table-wrap {
            overflow-x: auto;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 13px;
        }

        th {
            padding: 13px 17px;
            background: #f8faff;
            color: #7d8aa1;
            font-size: 10px;
            font-weight: 800;
            letter-spacing: .5px;
            text-align: left;
            text-transform: uppercase;
            white-space: nowrap;
        }

        td {
            padding: 14px 17px;
            border-top: 1px solid #eff3f8;
            color: #3b4861;
            white-space: nowrap;
        }

        tr:hover td {
            background: #fbfcff;
        }

        @@media (max-width: 900px) {
            .report-layout {
                grid-template-columns: 1fr;
            }
        }

        @@media (max-width: 620px) {
            .topbar {
                padding: 0 20px;
            }

            .page {
                padding: 25px 17px;
            }

            .page-heading {
                align-items: flex-start;
                flex-direction: column;
            }

            .column-grid {
                grid-template-columns: 1fr;
            }

            .filter-row {
                grid-template-columns: 1fr 1fr;
            }

            .remove-filter {
                grid-column: span 2;
                width: 100%;
            }

            .sort-grid {
                grid-template-columns: 1fr;
            }
        }

        .chart-panel {
            margin-top: 22px;
            padding: 23px;
            border: 1px solid var(--line);
            border-radius: 16px;
            background: #fff;
        }

        .chart-controls {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 11px;
            margin: 18px 0 22px;
        }

        .chart-control label {
            display: block;
            margin-bottom: 7px;
            color: var(--muted);
            font-size: 11px;
            font-weight: 750;
            text-transform: uppercase;
        }

        #reportChart {
            width: 100%;
            min-height: 370px;
        }

        @@media (max-width: 700px) {
            .chart-controls {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <header class="topbar">
        <a href="/Dashboard" class="brand">
            <span class="brand-mark">
                <svg viewBox="0 0 24 24" width="21" fill="none">
                    <path d="M4 18.5V11M10 18.5V5.5M16 18.5V9M22 18.5V2.5"
                          stroke="white" stroke-width="2.5"
                          stroke-linecap="round" />
                </svg>
            </span>
            Corporate Reporting
        </a>

        <a class="back-link" href="/Dashboard">← Dashboard’a dön</a>
    </header>

    <main class="page">
        <div class="page-heading">
            <div>
                <div class="breadcrumb">Raporlar / Yeni Rapor</div>
                <h1>Rapor oluştur</h1>
                <p>Veri kaynağını, kolonları ve filtreleri seçerek raporunuzu hazırlayın.</p>
            </div>
        </div>

        <section class="source-card">
            <h2 class="section-title">1. Veri kaynağını seçin</h2>
            <p class="section-subtitle">
                Yalnızca erişim yetkinizin bulunduğu onaylı kaynaklar listelenir.
            </p>

            <select class="source-select"
                    id="tableSelector"
                    onchange="changeDataSource(this.value)">
                <option value="">Veri kaynağı seçin</option>

                @foreach (var source in Model.DataSources)
                {
                    <option value="@source.Id"
                            selected="@(source.Id == selectedTableId)">
                        @source.DisplayName
                    </option>
                }
            </select>
        </section>

        @if (Model.AvailableColumns.Any())
        {
            <form method="post"
                  asp-page="/Reports/Create"
                  asp-route-tableId="@selectedTableId"
                  id="reportForm">
                <input type="hidden"
                       asp-for="Request.ReportableTableId"
                       value="@selectedTableId" />

                <div asp-validation-summary="ModelOnly"></div>

                <div class="report-layout">
                    <section class="panel">
                        <div class="panel-header">
                            <div>
                                <h2>2. Görüntülenecek kolonlar</h2>
                                <p>Raporda görmek istediğiniz alanları işaretleyin.</p>
                            </div>
                        </div>

                        <div class="column-grid">
                            @foreach (var column in Model.AvailableColumns)
                            {
                                var isSelected =
                                Model.Request.SelectedColumnIds.Contains(column.Id);

                                <label class="column-option">
                                    <input type="checkbox"
                                           name="Request.SelectedColumnIds"
                                           value="@column.Id"
                                           checked="@isSelected" />

                                    <span>
                                        <span class="column-name">@column.DisplayName</span>
                                        <span class="column-type">@column.DataType</span>
                                    </span>
                                </label>
                            }
                        </div>
                    </section>

                    <section class="panel">
                        <div class="panel-header">
                            <div>
                                <h2>3. Filtrele ve sırala</h2>
                                <p>İsteğe bağlı filtreler ile sonucunuzu daraltın.</p>
                            </div>
                        </div>

                        <div class="filter-list" id="filterList">
                            @for (var i = 0; i < Model.Request.Filters.Count; i++)
                            {
                                <div class="filter-row">
                                    <select class="select-field"
                                            name="Request.Filters[@i].ColumnId">
                                        @foreach (var column in Model.AvailableColumns.Where(x => x.IsFilterable))
                                        {
                                            <option value="@column.Id"
                                                    selected="@(column.Id == Model.Request.Filters[i].ColumnId)">
                                                @column.DisplayName
                                            </option>
                                        }
                                    </select>

                                    <select class="select-field"
                                            name="Request.Filters[@i].Operator">
                                        <option value="Equals">Eşittir</option>
                                        <option value="Contains">İçerir</option>
                                        <option value="GreaterThan">Büyüktür</option>
                                        <option value="LessThan">Küçüktür</option>
                                        <option value="Between">Arasında</option>
                                    </select>

                                    <input class="text-field"
                                           name="Request.Filters[@i].Value"
                                           value="@Model.Request.Filters[i].Value"
                                           placeholder="Değer" />

                                    <button type="button"
                                            class="remove-filter"
                                            onclick="removeFilter(this)">
                                        ×
                                    </button>
                                </div>
                            }
                        </div>

                        <template id="filterTemplate">
                            <div class="filter-row">
                                <select class="select-field"
                                        name="Request.Filters[__INDEX__].ColumnId">
                                    @foreach (var column in Model.AvailableColumns.Where(x => x.IsFilterable))
                                    {
                                        <option value="@column.Id">@column.DisplayName</option>
                                    }
                                </select>

                                <select class="select-field"
                                        name="Request.Filters[__INDEX__].Operator">
                                    <option value="Equals">Eşittir</option>
                                    <option value="Contains">İçerir</option>
                                    <option value="GreaterThan">Büyüktür</option>
                                    <option value="LessThan">Küçüktür</option>
                                    <option value="Between">Arasında</option>
                                </select>

                                <input class="text-field"
                                       name="Request.Filters[__INDEX__].Value"
                                       placeholder="Değer" />

                                <button type="button"
                                        class="remove-filter"
                                        onclick="removeFilter(this)">
                                    ×
                                </button>
                            </div>
                        </template>

                        <button type="button"
                                class="add-filter"
                                onclick="addFilter()">
                            + Filtre ekle
                        </button>

                        <div class="sort-box">
                            <p class="section-subtitle">Sıralama</p>

                            <div class="sort-grid">
                                <select asp-for="Request.SortColumnId"
                                        class="select-field">
                                    <option value="">Sıralama kolonu seçin</option>

                                    @foreach (var column in Model.AvailableColumns.Where(x => x.IsSortable))
                                    {
                                        <option value="@column.Id">@column.DisplayName</option>
                                    }
                                </select>

                                <select asp-for="Request.SortDirection"
                                        class="select-field">
                                    <option value="ASC">Artan</option>
                                    <option value="DESC">Azalan</option>
                                </select>
                            </div>
                        </div>

                        <button type="submit" class="run-button">
                            Raporu Çalıştır
                        </button>
                    </section>
                </div>
            </form>
        }
        else if (selectedTableId == 0)
        {
            <section class="empty-state">
                <div class="empty-icon">▤</div>
                <strong>Başlamak için bir veri kaynağı seçin.</strong>
                <p>Kolonlar ve filtre seçenekleri seçiminizden sonra görüntülenecek.</p>
            </section>
        }

        @if (Model.Result is not null)
        {
            @if (Model.Result is not null &&
                    Model.Result.Columns.Any(x =>
                    x.DataType == "int" || x.DataType == "decimal"))
            {
                <section class="chart-panel">
                    <div class="panel-header">
                        <div>
                            <h2>Grafik görünümü</h2>
                            <p>Rapor verinizi farklı grafik tipleriyle inceleyin.</p>
                        </div>
                    </div>

                    <div class="chart-controls">
                        <div class="chart-control">
                            <label for="chartType">Grafik tipi</label>
                            <select id="chartType" class="select-field">
                                <option value="ColumnChart">Sütun Grafik</option>
                                <option value="LineChart">Çizgi Grafik</option>
                                <option value="AreaChart">Alan Grafik</option>
                                <option value="PieChart">Pasta Grafik</option>
                            </select>
                        </div>

                        <div class="chart-control">
                            <label for="chartLabelColumn">Kategori (X ekseni)</label>
                            <select id="chartLabelColumn" class="select-field">
                                @foreach (var column in Model.Result.Columns)
                                {
                                    <option value="@column.Name">@column.DisplayName</option>
                                }
                            </select>
                        </div>

                        <div class="chart-control">
                            <label for="chartValueColumn">Değer (Y ekseni)</label>
                            <select id="chartValueColumn" class="select-field">
                                @foreach (var column in Model.Result.Columns.Where(x =>
                                                        x.DataType == "int" || x.DataType == "decimal"))
                                {
                                    <option value="@column.Name">@column.DisplayName</option>
                                }
                            </select>
                        </div>
                    </div>

                    <div id="reportChart"></div>
                </section>
            }
            <section class="result-panel">
                <div class="result-header">
                    <h2>Rapor sonucu</h2>
                    <span class="row-count">@Model.Result.TotalCount kayıt bulundu</span>
                </div>

                <div class="table-wrap">
                    <table>
                        <thead>
                            <tr>
                                @foreach (var column in Model.Result.Columns)
                                {
                                    <th>@column.DisplayName</th>
                                }
                            </tr>
                        </thead>

                        <tbody>
                            @if (Model.Result.Rows.Any())
                            {
                                @foreach (var row in Model.Result.Rows)
                                {
                                    <tr>
                                        @foreach (var column in Model.Result.Columns)
                                        {
                                            <td>@row.GetValueOrDefault(column.Name)</td>
                                        }
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="@Model.Result.Columns.Count">
                                        Filtrelerinize uygun kayıt bulunamadı.
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </section>
        }
    </main>
    <script src="https://www.gstatic.com/charts/loader.js"></script>
    @if (Model.Result is not null &&
        Model.Result.Columns.Any(x =>
        x.DataType == "int" || x.DataType == "decimal"))
    {
        <script>
            const reportColumns = @Html.Raw(
                            JsonSerializer.Serialize(Model.Result.Columns));

        const reportRows = @Html.Raw(
                        JsonSerializer.Serialize(Model.Result.Rows));

        google.charts.load("current", { packages: ["corechart"] });
        google.charts.setOnLoadCallback(drawReportChart);

            document.getElementById("chartType")
                .addEventListener("change", drawReportChart);

            document.getElementById("chartLabelColumn")
                .addEventListener("change", drawReportChart);

            document.getElementById("chartValueColumn")
                .addEventListener("change", drawReportChart);

            function drawReportChart() {
                const chartType = document.getElementById("chartType").value;
                const labelColumn = document.getElementById("chartLabelColumn").value;
                const valueColumn = document.getElementById("chartValueColumn").value;

                const labelName = reportColumns
                    .find(x => x.Name === labelColumn).DisplayName;

                const valueName = reportColumns
                    .find(x => x.Name === valueColumn).DisplayName;

                const groupedData = new Map();

                reportRows.forEach(row => {
                    const label = String(row[labelColumn] ?? "Belirtilmemiş");
                    const value = Number(row[valueColumn]);

                    if (!Number.isFinite(value)) {
                        return;
                    }

                    groupedData.set(
                        label,
                        (groupedData.get(label) ?? 0) + value
                    );
                });

                const data = new google.visualization.DataTable();

                data.addColumn("string", labelName);
                data.addColumn("number", valueName);

                data.addRows(
                    Array.from(groupedData.entries())
                );

                const options = {
                    backgroundColor: "transparent",
                    colors: ["#386fff", "#20d6ca", "#f59f42", "#18ad7e"],
                    fontName: "Segoe UI",
                    legend: chartType === "PieChart"
                        ? { position: "right" }
                        : { position: "none" },
                    chartArea: {
                        left: chartType === "PieChart" ? 20 : 65,
                        top: 25,
                        width: "84%",
                        height: "76%"
                    },
                    hAxis: {
                        textStyle: { color: "#71809b", fontSize: 11 }
                    },
                    vAxis: {
                        minValue: 0,
                        textStyle: { color: "#71809b", fontSize: 11 },
                        gridlines: { color: "#edf1f7" }
                    },
                    pieHole: chartType === "PieChart" ? 0.48 : 0
                };

                const chart = new google.visualization[chartType](
                    document.getElementById("reportChart")
                );

                chart.draw(data, options);
            }
        </script>
        }
    <script>
        function changeDataSource(tableId) {
            if (!tableId) {
                return;
            }

            window.location.href = "/Reports/Create?tableId=" + tableId;
        }

        function addFilter() {
            const filterList = document.getElementById("filterList");
            const template = document.getElementById("filterTemplate").innerHTML;
            const nextIndex = filterList.children.length;

            filterList.insertAdjacentHTML(
                "beforeend",
                template.replaceAll("__INDEX__", nextIndex)
            );
        }

        function removeFilter(button) {
            button.closest(".filter-row").remove();

            const rows = document.querySelectorAll("#filterList .filter-row");

            rows.forEach((row, index) => {
                row.querySelectorAll("[name]").forEach(input => {
                    input.name = input.name.replace(
                        /Request\.Filters\[\d+\]/,
                        "Request.Filters[" + index + "]"
                    );
                });
            });
        }
    </script>
</body>
</html>
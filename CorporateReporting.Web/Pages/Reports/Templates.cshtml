@page
@model CorporateReporting.Web.Pages.Reports.TemplatesModel

@{
    Layout = null;
    ViewData["Title"] = "Rapor Şablonları";
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Rapor Şablonları | Corporate Reporting</title>

    <style>
        :root {
            --navy: #0a1731;
            --blue: #386fff;
            --cyan: #20d6ca;
            --bg: #f4f7fc;
            --surface: #fff;
            --line: #e7edf6;
            --text: #1b2945;
            --muted: #8190a8;
            --green: #168b66;
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            color: var(--text);
            background: var(--bg);
            font-family: Inter, "Segoe UI", Arial, sans-serif;
        }

        .topbar {
            height: 72px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 38px;
            border-bottom: 1px solid var(--line);
            background: #fff;
        }

        .brand {
            display: flex;
            align-items: center;
            gap: 11px;
            color: var(--navy);
            font-size: 16px;
            font-weight: 800;
            text-decoration: none;
        }

        .brand-mark {
            width: 37px;
            height: 37px;
            display: grid;
            place-items: center;
            border-radius: 11px;
            background: linear-gradient(135deg, var(--cyan), var(--blue));
        }

        .page {
            max-width: 1250px;
            margin: 0 auto;
            padding: 38px 32px;
        }

        .page-header {
            display: flex;
            align-items: end;
            justify-content: space-between;
            gap: 20px;
            margin-bottom: 30px;
        }

        .eyebrow {
            margin-bottom: 9px;
            color: var(--blue);
            font-size: 11px;
            font-weight: 800;
            letter-spacing: .7px;
            text-transform: uppercase;
        }

        h1 {
            margin: 0;
            font-size: 30px;
            letter-spacing: -1px;
        }

        .page-header p {
            margin: 9px 0 0;
            color: var(--muted);
            font-size: 14px;
        }

        .new-button {
            padding: 12px 16px;
            border-radius: 10px;
            background: linear-gradient(135deg, #386fff, #2857dd);
            box-shadow: 0 10px 20px rgba(56,111,255,.2);
            color: #fff;
            font-size: 13px;
            font-weight: 750;
            text-decoration: none;
        }

        .template-grid {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 17px;
        }

        .template-card {
            position: relative;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            min-height: 235px;
            padding: 21px;
            border: 1px solid var(--line);
            border-radius: 16px;
            background: var(--surface);
            transition: transform .2s ease, box-shadow .2s ease;
        }

            .template-card:hover {
                transform: translateY(-4px);
                box-shadow: 0 14px 28px rgba(22, 45, 93, .09);
            }

            .template-card::after {
                content: "";
                position: absolute;
                top: -55px;
                right: -55px;
                width: 135px;
                height: 135px;
                border-radius: 50%;
                background: radial-gradient(circle, rgba(56,111,255,.13), transparent 68%);
            }

        .card-top {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 10px;
        }

        .source-icon {
            width: 43px;
            height: 43px;
            display: grid;
            place-items: center;
            border-radius: 12px;
            background: #eaf0ff;
            color: var(--blue);
            font-size: 20px;
        }

        .shared-badge {
            padding: 6px 9px;
            border-radius: 20px;
            background: #e8f8f1;
            color: var(--green);
            font-size: 10px;
            font-weight: 800;
        }

        .personal-badge {
            padding: 6px 9px;
            border-radius: 20px;
            background: #eff2f7;
            color: #68758d;
            font-size: 10px;
            font-weight: 800;
        }

        .template-card h2 {
            margin: 18px 0 7px;
            font-size: 17px;
            letter-spacing: -.3px;
        }

        .source-name {
            color: var(--muted);
            font-size: 12px;
        }

        .card-footer {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 10px;
            margin-top: auto;
            padding-top: 18px;
            border-top: 1px solid #eef2f7;
        }

        .owner {
            color: #76839b;
            font-size: 11px;
        }

        .open-button {
            padding: 8px 11px;
            border-radius: 8px;
            background: #eff3ff;
            color: var(--blue);
            font-size: 11px;
            font-weight: 800;
            text-decoration: none;
        }

        .empty-state {
            padding: 65px 25px;
            border: 1px dashed #ccd8eb;
            border-radius: 16px;
            background: rgba(255,255,255,.6);
            color: var(--muted);
            text-align: center;
        }

        .empty-icon {
            width: 54px;
            height: 54px;
            display: grid;
            place-items: center;
            margin: 0 auto 13px;
            border-radius: 15px;
            background: #eaf0ff;
            color: var(--blue);
            font-size: 25px;
        }

        @@media (max-width: 980px) {
            .template-grid {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }
        }

        @@media (max-width: 620px) {
            .topbar {
                padding: 0 20px;
            }

            .page {
                padding: 28px 18px;
            }

            .page-header {
                align-items: flex-start;
                flex-direction: column;
            }

            .template-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>

<body>
    <header class="topbar">
        <a href="/Dashboard" class="brand">
            <span class="brand-mark">▥</span>
            Corporate Reporting
        </a>

        <a href="/Dashboard"
           style="color:#61708b;text-decoration:none;font-size:13px;font-weight:650;">
            ← Dashboard’a dön
        </a>
    </header>

    <main class="page">
        <div class="page-header">
            <div>
                <div class="eyebrow">Raporlar / Şablonlar</div>
                <h1>Rapor şablonları</h1>
                <p>Kayıtlı rapor ayarlarınızı tek tıkla yeniden kullanın.</p>
            </div>

            <a href="/Reports/Create" class="new-button">
                + Yeni rapor oluştur
            </a>
        </div>

        @if (Model.Templates.Any())
        {
            <section class="template-grid">
                @foreach (var template in Model.Templates)
                {
                    <article class="template-card">
                        <div class="card-top">
                            <div class="source-icon">▤</div>

                            @if (template.IsShared)
                            {
                                <span class="shared-badge">PAYLAŞILDI</span>
                            }
                            else
                            {
                                <span class="personal-badge">KİŞİSEL</span>
                            }
                        </div>

                        <h2>@template.Name</h2>

                        <div class="source-name">
                            Veri kaynağı: @template.ReportableTable.DisplayName
                        </div>

                        <div class="card-footer">
                            <div class="owner">
                                @template.User.FullName ·
                                @template.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy")
                            </div>

                            <a class="open-button"
                               href="/Reports/Create?tableId=@template.ReportableTableId">
                                Aç →
                            </a>
                        </div>
                    </article>
                }
            </section>
        }
        else
        {
            <section class="empty-state">
                <div class="empty-icon">▤</div>
                <strong>Henüz kaydedilmiş şablon yok.</strong>
                <p>Bir rapor oluşturup “Şablonu Kaydet” ile ilk şablonunuzu ekleyin.</p>
            </section>
        }
    </main>
</body>
</html>
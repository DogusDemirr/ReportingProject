@page
@model CorporateReporting.Web.Pages.Account.LoginModel

@{
    Layout = null;
    ViewData["Title"] = "Giriş Yap";
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Giriş Yap | Kurumsal Raporlama</title>

    <style>
        :root {
            --navy: #08152e;
            --navy-light: #132b58;
            --blue: #3978ff;
            --cyan: #26d7d1;
            --text: #17233d;
            --muted: #73809a;
            --line: #e7ebf3;
            --danger: #e45168;
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            min-height: 100vh;
            font-family: Inter, "Segoe UI", Arial, sans-serif;
            background: #f4f7fc;
            color: var(--text);
        }

        .login-page {
            min-height: 100vh;
            display: grid;
            grid-template-columns: 1.05fr 0.95fr;
        }

        .brand-panel {
            position: relative;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            padding: 52px;
            color: #fff;
            background:
                radial-gradient(circle at 18% 18%, rgba(51, 220, 212, .35), transparent 28%),
                radial-gradient(circle at 82% 76%, rgba(66, 118, 255, .45), transparent 32%),
                linear-gradient(145deg, #07132c 0%, #0d2450 55%, #142c62 100%);
        }

        .brand-panel::before,
        .brand-panel::after {
            content: "";
            position: absolute;
            width: 360px;
            height: 360px;
            border: 1px solid rgba(255, 255, 255, .12);
            border-radius: 50%;
        }

        .brand-panel::before {
            top: -155px;
            right: -125px;
        }

        .brand-panel::after {
            bottom: -200px;
            left: -130px;
            width: 440px;
            height: 440px;
        }

        .brand,
        .brand-content,
        .brand-footer {
            position: relative;
            z-index: 1;
        }

        .brand {
            display: flex;
            align-items: center;
            gap: 12px;
            font-size: 18px;
            font-weight: 700;
            letter-spacing: -.3px;
        }

        .brand-mark {
            width: 42px;
            height: 42px;
            display: grid;
            place-items: center;
            border-radius: 13px;
            background: linear-gradient(135deg, var(--cyan), #4d79ff);
            box-shadow: 0 12px 28px rgba(21, 210, 211, .26);
        }

        .brand-content {
            max-width: 550px;
        }

        .eyebrow {
            display: inline-block;
            padding: 7px 12px;
            border: 1px solid rgba(255, 255, 255, .17);
            border-radius: 999px;
            color: #b9d5ff;
            font-size: 12px;
            font-weight: 700;
            letter-spacing: 1.2px;
            text-transform: uppercase;
        }

        .brand-content h1 {
            max-width: 500px;
            margin: 22px 0 18px;
            font-size: clamp(38px, 4vw, 62px);
            line-height: 1.08;
            letter-spacing: -2.2px;
        }

        .brand-content p {
            max-width: 455px;
            margin: 0;
            color: #b8c8e6;
            font-size: 17px;
            line-height: 1.7;
        }

        .feature-list {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            margin-top: 34px;
        }

        .feature-item {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 9px 12px;
            border-radius: 10px;
            background: rgba(255, 255, 255, .08);
            border: 1px solid rgba(255, 255, 255, .08);
            font-size: 13px;
            color: #dbe9ff;
        }

        .feature-item svg {
            color: var(--cyan);
        }

        .brand-footer {
            color: #7892bc;
            font-size: 13px;
        }

        .login-panel {
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 32px;
            background:
                radial-gradient(circle at 90% 7%, rgba(57, 120, 255, .1), transparent 22%),
                #f8faff;
        }

        .login-card {
            width: 100%;
            max-width: 440px;
        }

        .mobile-brand {
            display: none;
        }

        .login-card h2 {
            margin: 0 0 10px;
            font-size: 32px;
            letter-spacing: -1.1px;
        }

        .login-card > p {
            margin: 0 0 35px;
            color: var(--muted);
            line-height: 1.55;
        }

        .validation-summary-errors {
            margin-bottom: 20px;
            padding: 12px 14px;
            border: 1px solid #ffd9df;
            border-radius: 10px;
            background: #fff4f6;
            color: var(--danger);
            font-size: 14px;
        }

        .validation-summary-errors ul {
            margin: 0;
            padding-left: 18px;
        }

        .form-group {
            margin-bottom: 21px;
        }

        .form-label {
            display: block;
            margin-bottom: 8px;
            font-size: 14px;
            font-weight: 650;
            color: #2d3b57;
        }

        .form-control {
            width: 100%;
            height: 52px;
            padding: 0 15px;
            border: 1px solid var(--line);
            border-radius: 12px;
            outline: none;
            background: #fff;
            color: var(--text);
            font: inherit;
            transition: border-color .2s, box-shadow .2s;
        }

        .form-control:focus {
            border-color: var(--blue);
            box-shadow: 0 0 0 4px rgba(57, 120, 255, .12);
        }

        .field-validation-error {
            display: block;
            margin-top: 7px;
            color: var(--danger);
            font-size: 12px;
        }

        .login-options {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin: 2px 0 27px;
            font-size: 14px;
        }

        .remember-me {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            color: #53617c;
            cursor: pointer;
        }

        .remember-me input {
            width: 16px;
            height: 16px;
            accent-color: var(--blue);
        }

        .forgot-password {
            color: var(--blue);
            text-decoration: none;
            font-weight: 600;
        }

        .login-button {
            width: 100%;
            height: 54px;
            border: 0;
            border-radius: 12px;
            background: linear-gradient(135deg, #386fff, #2854d9);
            color: #fff;
            cursor: pointer;
            font: inherit;
            font-weight: 700;
            box-shadow: 0 13px 23px rgba(47, 96, 226, .25);
            transition: transform .2s, box-shadow .2s;
        }

        .login-button:hover {
            transform: translateY(-2px);
            box-shadow: 0 17px 28px rgba(47, 96, 226, .32);
        }

        .security-note {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 7px;
            margin-top: 26px;
            color: #8490a7;
            font-size: 12px;
        }

        @@media (max-width: 900px) {
            .login-page {
                grid-template-columns: 1fr;
            }

            .brand-panel {
                display: none;
            }

            .login-panel {
                min-height: 100vh;
            }

            .mobile-brand {
                display: flex;
                align-items: center;
                gap: 10px;
                margin-bottom: 42px;
                color: var(--navy);
                font-size: 17px;
                font-weight: 750;
            }

            .mobile-brand .brand-mark {
                width: 38px;
                height: 38px;
            }
        }

        @@media (max-width: 480px) {
            .login-panel {
                padding: 24px;
            }

            .login-card h2 {
                font-size: 28px;
            }

            .login-options {
                align-items: flex-start;
                flex-direction: column;
                gap: 15px;
            }
        }
    </style>
</head>
<body>
    <main class="login-page">
        <section class="brand-panel">
            <div class="brand">
                <div class="brand-mark">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                        <path d="M4 18.5V11M10 18.5V5.5M16 18.5V9M22 18.5V2.5"
                              stroke="white" stroke-width="2.5"
                              stroke-linecap="round" />
                    </svg>
                </div>
                Corporate Reporting
            </div>

            <div class="brand-content">
                <span class="eyebrow">Veriyi karara dönüştürün</span>

                <h1>Raporlama deneyiminizi yeniden tanımlayın.</h1>

                <p>
                    Kurumsal verilerinizi güvenle analiz edin, anlamlı
                    raporlara dönüştürün ve ekibinizle paylaşın.
                </p>

                <div class="feature-list">
                    <span class="feature-item">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
                            <path d="m5 12 4 4L19 6" stroke="currentColor"
                                  stroke-width="2.5" stroke-linecap="round"
                                  stroke-linejoin="round" />
                        </svg>
                        Dinamik raporlar
                    </span>

                    <span class="feature-item">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
                            <path d="m5 12 4 4L19 6" stroke="currentColor"
                                  stroke-width="2.5" stroke-linecap="round"
                                  stroke-linejoin="round" />
                        </svg>
                        Güvenli erişim
                    </span>

                    <span class="feature-item">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
                            <path d="m5 12 4 4L19 6" stroke="currentColor"
                                  stroke-width="2.5" stroke-linecap="round"
                                  stroke-linejoin="round" />
                        </svg>
                        Anlık içgörü
                    </span>
                </div>
            </div>

            <div class="brand-footer">
                © @DateTime.Now.Year Corporate Reporting Platform
            </div>
        </section>

        <section class="login-panel">
            <div class="login-card">
                <div class="mobile-brand">
                    <div class="brand-mark">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
                            <path d="M4 18.5V11M10 18.5V5.5M16 18.5V9M22 18.5V2.5"
                                  stroke="white" stroke-width="2.5"
                                  stroke-linecap="round" />
                        </svg>
                    </div>
                    Corporate Reporting
                </div>

                <h2>Tekrar hoş geldiniz</h2>
                <p>Raporlarınıza erişmek için bilgilerinizi girin.</p>

                <form method="post">
                    <div asp-validation-summary="ModelOnly"></div>

                    <div class="form-group">
                        <label asp-for="Input.Email" class="form-label">
                            E-posta adresi
                        </label>

                        <input asp-for="Input.Email"
                               class="form-control"
                               placeholder="ornek@sirket.com"
                               autocomplete="email" />

                        <span asp-validation-for="Input.Email"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Input.Password" class="form-label">
                            Şifre
                        </label>

                        <input asp-for="Input.Password"
                               class="form-control"
                               placeholder="Şifrenizi girin"
                               autocomplete="current-password" />

                        <span asp-validation-for="Input.Password"></span>
                    </div>

                    <div class="login-options">
                        <label class="remember-me">
                            <input asp-for="Input.RememberMe" />
                            Beni hatırla
                        </label>

                        <a href="#" class="forgot-password">Şifremi unuttum</a>
                    </div>

                    <button type="submit" class="login-button">
                        Güvenli Giriş Yap
                    </button>
                </form>

                <div class="security-note">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none">
                        <rect x="5" y="10" width="14" height="10" rx="2"
                              stroke="currentColor" stroke-width="2" />
                        <path d="M8 10V7a4 4 0 0 1 8 0v3"
                              stroke="currentColor" stroke-width="2"
                              stroke-linecap="round" />
                    </svg>
                    Bağlantınız güvenli şekilde korunmaktadır.
                </div>
            </div>
        </section>
    </main>
</body>
</html>